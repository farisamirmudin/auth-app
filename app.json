{
	"expo": {
		"name": "auth-app",
		"slug": "auth-app",
		"version": "1.0.0",
		"orientation": "default",
		"icon": "./assets/icon.png",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"experiments": {
			"reactCompiler": true
		},
		"scheme": "authapp",
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.authapp"
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./assets/adaptive-icon.png",
				"backgroundColor": "#e0f2fe"
			},
			"package": "com.authapp"
		},
		"web": {
			"favicon": "./assets/favicon.png"
		},
		"plugins": [
			"expo-asset",
			[
				"expo-splash-screen",
				{
					"backgroundColor": "#e0f2fe",
					"image": "./assets/splash-icon.png"
				}
			]
		]
	}
}
